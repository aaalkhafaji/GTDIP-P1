# Fig 4: Edge Alignment Map (NEW)
def get_edge_map(img):
    edges = np.zeros_like(img)
    for c in range(3):
        gx, gy = grad(img[:,:,c])
        edges[:,:,c] = np.sqrt(gx**2 + gy**2)
    return np.clip(edges * 3, 0, 1)  # Scale up for visibility

fig, ax = plt.subplots(1, 2, figsize=(12, 6))
ax[0].imshow(get_edge_map(noisy_image))
ax[0].set_title("Initial Gradients (Misaligned / Chromatic Fringing)")
ax[0].axis('off')
ax[1].imshow(get_edge_map(denoised_image))
ax[1].set_title("Equilibrium Gradients (Perfect White Alignment)")
ax[1].axis('off')
save_fig("fig4_edge_alignment")

