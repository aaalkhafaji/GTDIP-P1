# Fig 2: Energy Convergence
plt.figure(figsize=(8, 5))
plt.plot(energies['R'], label='Player R ($J_R$)', color='#e74c3c', linewidth=2)
plt.plot(energies['G'], label='Player G ($J_G$)', color='#2ecc71', linewidth=2)
plt.plot(energies['B'], label='Player B ($J_B$)', color='#3498db', linewidth=2)
plt.xlabel("Iteration (Artificial Time $t$)"); plt.ylabel("Cost Functional Value")
